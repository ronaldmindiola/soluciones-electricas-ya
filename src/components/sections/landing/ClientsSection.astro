---
import { Image } from 'astro:assets';

import claro from '@images/ya/brands/claro.png';
import alpina from '@images/ya/brands/alpina.png';
import betplay from '@images/ya/brands/betplay.png';
import cocacola from '@images/ya/brands/coca-cola.png';
import eucerin from '@images/ya/brands/eucerin.png';
import zte from '@images/ya/brands/zte.png';

// Define props from Astro
const { title, subTitle } = Astro.props;

// Lista de imágenes
const brands = [
  { src: claro, alt: 'Claro' },
  { src: alpina, alt: 'Alpina' },
  { src: betplay, alt: 'BetPlay' },
  { src: cocacola, alt: 'Coca Cola' },
  { src: eucerin, alt: 'Eucerin' },
  { src: zte, alt: 'ZTE' }
];

// Define TypeScript interface for props
interface Props {
  title: string;
  subTitle?: string;
}
---

<section
  class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14 2xl:max-w-full">
  <!-- Título y descripción -->
  <div class="mx-auto mb-6 w-full space-y-1 text-center sm:w-1/2 lg:w-1/3">
    <h2 class="text-2xl font-bold leading-tight text-neutral-800 dark:text-neutral-200 sm:text-3xl">
      {title}
    </h2>
    {subTitle && (
      <p class="text-neutral-600 dark:text-neutral-400 leading-tight">{subTitle}</p>
    )}
  </div>

  <!-- Contenedor de marcas -->
  <div class="flex flex-wrap items-center justify-center gap-6 sm:gap-12 lg:gap-16">
    {brands.map((brand) => (
      <Image width={80} height={80} src={brand.src} alt={brand.alt} class="object-contain" />
    ))}
  </div>
</section>
