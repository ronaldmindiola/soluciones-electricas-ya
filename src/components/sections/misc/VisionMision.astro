---
interface Props {
  title?: string;
  vision: string;
  mision: string;
  values?: string;
}

const { vision, mision } = Astro.props;
---

<section class="container mx-auto space-y-12 p-6 lg:px-8 ">
  <div class="grid gap-8 lg:grid-cols-2">
    <div class="rounded-lg p-6 transition-all duration-300 shadow-sm text-center">
      <div class="mb-4 flex items-center space-x-4 justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="text-orange-400 dark:text-orange-400" fill="currentColor" id="Isolation_Mode" data-name="Isolation Mode" viewBox="0 0 24 24" width="24" height="24"><path d="M23.8,11.478c-.13-.349-3.3-8.538-11.8-8.538S.326,11.129.2,11.478L0,12l.2.522c.13.349,3.3,8.538,11.8,8.538s11.674-8.189,11.8-8.538L24,12ZM12,18.085c-5.418,0-8.041-4.514-8.79-6.085C3.961,10.425,6.585,5.915,12,5.915S20.038,10.424,20.79,12C20.038,13.576,17.415,18.085,12,18.085Z"/><circle cx="12" cy="12" r="4"/></svg>
        <h2
          class="text-3xl font-extrabold text-neutral-800 dark:text-neutral-200"
        >
          Visión
        </h2>
      </div>
      <p class="text-lg leading-relaxed text-neutral-600 dark:text-neutral-400">
        {vision}
      </p>
    </div>
    <div class="rounded-lg p-6 transition-all duration-300 shadow-sm text-center">
      <div class="mb-4 flex items-center space-x-4 justify-center">
        
        

        <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" class="text-orange-400 dark:text-orange-400" id="Layer_1" height="24" viewBox="0 0 24 24" width="24"  data-name="Layer 1"><path d="m24 9v2h-6l-5-5h8a3 3 0 0 1 3 3zm-24 0v2h6l5-5h-8a3 3 0 0 0 -3 3zm17-6.5-4-2.5h-2v6h2v-1zm.172 10.5h6.828v11h-9v-4a3 3 0 0 0 -6 0v4h-9v-11h6.828l5.172-5zm-11.172 7h-3v2h3zm0-4h-3v2h3zm8-3a2 2 0 1 0 -2 2 2 2 0 0 0 2-2zm4 5h3v-2h-3zm0 4h3v-2h-3zm-6-3a1 1 0 0 0 -1 1v4h2v-4a1 1 0 0 0 -1-1z"/></svg>
        <h2
          class="text-3xl font-extrabold text-neutral-800 dark:text-neutral-200"
        >
          Misión
        </h2>
      </div>
      <p class="text-lg leading-relaxed text-neutral-600 dark:text-neutral-400">
        {mision}
      </p>
    </div>
  </div>
</section>
<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  section > div {
    animation: fadeIn 0.5s ease-out forwards;
    opacity: 0;
  }

  section > div:nth-child(1) {
    animation-delay: 0.1s;
  }
  section > div:nth-child(2) {
    animation-delay: 0.3s;
  }
  section > div:nth-child(3) {
    animation-delay: 0.5s;
  }
  section > div:nth-child(4) {
    animation-delay: 0.7s;
  }
</style>