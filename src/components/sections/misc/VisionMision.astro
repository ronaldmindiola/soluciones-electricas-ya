---
interface Props {
  title?: string;
  vision: string;
  mision: string;
  values?: string;
}

const { vision, mision } = Astro.props;
---

<section class="container mx-auto space-y-12 p-6 lg:px-8">
  <div class="grid gap-8 lg:grid-cols-2">
    <div class="rounded-lg p-6 transition-all duration-300 shadow-sm text-center">
      <div class="mb-4 flex items-center space-x-4 justify-center">
        <div class="h-8 w-8 text-neutral-700 hidden md:block">i</div>
        <h2
          class="text-3xl font-extrabold text-neutral-800 dark:text-neutral-200"
        >
          Visión
        </h2>
      </div>
      <p class="text-lg leading-relaxed text-neutral-600 dark:text-neutral-400">
        {vision}
      </p>
    </div>
    <div class="rounded-lg p-6 transition-all duration-300 shadow-sm text-center">
      <div class="mb-4 flex items-center space-x-4 justify-center">
        <div class="h-8 w-8 text-neutral-700 hidden md:block">i</div>
        <h2
          class="text-3xl font-extrabold text-neutral-800 dark:text-neutral-200"
        >
          Misión
        </h2>
      </div>
      <p class="text-lg leading-relaxed text-neutral-600 dark:text-neutral-400">
        {mision}
      </p>
    </div>
  </div>
</section>
<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  section > div {
    animation: fadeIn 0.5s ease-out forwards;
    opacity: 0;
  }

  section > div:nth-child(1) {
    animation-delay: 0.1s;
  }
  section > div:nth-child(2) {
    animation-delay: 0.3s;
  }
  section > div:nth-child(3) {
    animation-delay: 0.5s;
  }
  section > div:nth-child(4) {
    animation-delay: 0.7s;
  }
</style>