---
const {
  label = Astro.currentLocale === "fr" ? "Mot de passe" : "Password",
  forgot,
  id,
  errorId,
  content
} = Astro.props;

const requirements = Astro.currentLocale === "fr" 
  ? ["8 caractères minimum", "Une lettre majuscule", "Une lettre minuscule", "Un chiffre"]
  : ["8 characters minimum", "One uppercase letter", "One lowercase letter", "One number"];

interface Props {
  label?: string;
  forgot?: boolean;
  id?: string;
  errorId?: string;
  content?: string;
}
---

<div>
  <div class="flex items-center justify-between">
    <label
      for={id}
      class="mb-2 block text-sm text-neutral-800 dark:text-neutral-200"
      >{label}</label
    >
    {
      forgot ? (
        <button
          class="rounded-lg text-sm font-medium text-orange-400 decoration-2 outline-none ring-zinc-500 hover:underline focus-visible:ring dark:text-orange-400 dark:ring-zinc-200 dark:focus:outline-none dark:focus:ring-1"
          data-hs-overlay="#hs-toggle-between-modals-recover-modal"
        >
          {Astro.currentLocale === "fr" ? "Mot de passe oublié ?" : "Forgot password?"}
        </button>
      ) : (
        ""
      )
    }
  </div>
  <div class="relative">
    <input
      type="password"
      id={id}
      name="password"
      pattern="(?=.*\d)(?=.*[a-z])(?=.*[A-Z]).{8,}"
      class="block w-full rounded-lg border border-neutral-200 bg-neutral-50 px-4 py-3 text-sm text-neutral-700 focus:border-neutral-200 focus:outline-none focus:ring focus:ring-neutral-400 disabled:pointer-events-none disabled:opacity-50 dark:border-neutral-600 dark:bg-neutral-700/30 dark:text-neutral-300 dark:focus:ring-1"
      required
      aria-describedby={errorId}
      data-error-visible="false"
    />
    <div class="pointer-events-none absolute inset-y-0 end-0 hidden pe-3" data-error-icon>
      <svg
        class="h-5 w-5 text-red-500"
        width="16"
        height="16"
        fill="currentColor"
        viewBox="0 0 16 16"
        aria-hidden="true"
      >
        <path
          d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zM8 4a.905.905 0 0 0-.9.995l.35 3.507a.552.552 0 0 0 1.1 0l.35-3.507A.905.905 0 0 0 8 4zm.002 6a1 1 0 1 0 0 2 1 1 0 0 0 0-2z"
        ></path>
      </svg>
    </div>
  </div>
  <div class="mt-2 text-xs">
    <p class="text-neutral-600 dark:text-neutral-400">{Astro.currentLocale === "fr" ? "Le mot de passe doit contenir :" : "Password must contain:"}</p>
    <ul class="mt-1 space-y-1 ps-4">
      {requirements.map((req, index) => (
        <li>
          <span class="text-red-500" data-requirement={index}>✕</span> {req}
        </li>
      ))}
    </ul>
  </div>
  <p class="mt-2 hidden text-xs text-red-600" id={errorId}>
    {content || (Astro.currentLocale === "fr" 
      ? "Veuillez respecter tous les critères du mot de passe" 
      : "Please meet all password requirements")}
  </p>
</div>

<script>
  document.querySelectorAll('input[type="password"]').forEach(input => {
    const validatePassword = (value: string) => {
      const requirements = [
        value.length >= 8,
        /[A-Z]/.test(value),
        /[a-z]/.test(value),
        /\d/.test(value)
      ];
      
      requirements.forEach((met, index) => {
        const reqElement = document.querySelector(`[data-requirement="${index}"]`);
        if (reqElement) {
          reqElement.textContent = met ? "✓" : "✕";
          reqElement.classList.toggle("text-green-500", met);
          reqElement.classList.toggle("text-red-500", !met);
        }
      });
      
      return requirements.every(r => r);
    };

    input.addEventListener('input', function(e) {
      const target = e.target as HTMLInputElement;
      const errorIcon = target.parentElement?.querySelector('[data-error-icon]');
      const errorMessage = document.getElementById(target.getAttribute('aria-describedby') || '');
      
      const isValid = validatePassword(target.value);
      
      if (errorIcon) {
        errorIcon.classList.toggle('hidden', isValid);
      }
      if (errorMessage) {
        errorMessage.classList.toggle('hidden', isValid);
      }
      
      target.dataset.errorVisible = (!isValid).toString();
    });
  });
</script>
