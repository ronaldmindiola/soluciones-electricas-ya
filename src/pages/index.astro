---
// Import the necessary components
import MainLayout from "@/layouts/MainLayout.astro";
import FeaturesGeneral from "@components/sections/features/FeaturesGeneral.astro";
import FeaturesNavs from "@components/sections/features/FeaturesNavs.astro";
import ClientsSection from "@components/sections/landing/ClientsSection.astro";
import HeroSection from "@/assets/HeroSection.astro";
import HeroSectionAlt from "@components/sections/landing/HeroSectionAlt.astro";
import FAQ from "@components/sections/misc/FAQ.astro";
import PricingSection from "@components/sections/pricing/PricingSection.astro";
import TestimonialsSection from "@components/sections/testimonials/TestimonialsSection.astro";
import AnnouncementBanner from "@components/ui/banners/AnnouncementBanner.astro";
import faqs from "@data/faqs.json";
import features from "@data/features.json";
import pricing from "@data/pricing.json";
import tools from "@images/tools.png";
import construction from "@images/construccion.png";
import dashboard from "@images/dashboard.png";
import featureImage from "@images/ya/features.jpg";
import heroImage from "@images/hero.jpg";
import FeaturesCarousel from "@/components/sections/features/FeaturesCarousel.astro";

const avatarSrcs: Array<string> = [
  "https://images.unsplash.com/photo-1568602471122-7832951cc4c5?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=facearea&facepad=2&w=300&h=300&q=80",
  "https://images.unsplash.com/photo-1531927557220-a9e23c1e4794?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=facearea&facepad=2&w=300&h=300&q=80",
  "https://images.unsplash.com/photo-1541101767792-f9b2b1c4f127?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&&auto=format&fit=facearea&facepad=3&w=300&h=300&q=80",
  "https://images.unsplash.com/photo-1492562080023-ab3db95bfbce?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=facearea&facepad=2&w=300&h=300&q=80",
];


---

<MainLayout>
  <!-- <AnnouncementBanner
    btnId="dismiss-button"
    btnTitle="Contáctanos para Más Información"
    url="/products"
  /> -->
  

  <HeroSection
    title={`Soluciones Eléctricas Ya!`}
    subTitle="Innovación eléctrica al alcance de tu mano. Más de 20 años encendiendo tus ideas."
    primaryBtn="Descubre Nuestras Soluciones"
    primaryBtnURL="/productos"
    secondaryBtn="Contactar Equipo de Ventas"
    secondaryBtnURL="/contact"
    withReview={true}
    avatars={avatarSrcs}
    rating={`<span class="font-bold">5.0</span> / 5`}
    starCount={5}
    reviews={`De más de <span class="font-bold">15k</span> reseñas`}
    src={heroImage}
    alt="Imagen de productos eléctricos de Soluciones Eléctricas YA SAS"
  />

  <ClientsSection
    title="Confiado por Líderes del Sector"
    subTitle="Más de 20 años ofreciendo soluciones eléctricas confiables y de calidad."
  />

  <FeaturesCarousel />

  <FeaturesGeneral
    title="Satisfaciendo las Demandas del Sector Eléctrico"
    subTitle="En Soluciones Eléctricas YA SAS, ofrecemos soluciones innovadoras en iluminación, mobiliario y servicios eléctricos. Nos especializamos en superar los desafíos únicos de cada proyecto, garantizando calidad, eficiencia y tiempos de entrega confiables para ayudarte a alcanzar tus metas."
    src={featureImage}
    alt="Productos de Soluciones Eléctricas YA en exhibición"
    features={features}
  />

  <FeaturesNavs
  title={`Personaliza <span class="block text-yellow-500 dark:text-yellow-400">Soluciones Eléctricas YA</span> para adaptarse a tus necesidades de iluminación.`}

  tabs={[
    {
      heading: "Herramientas de Vanguardia",
      content:
        "Impulsa tus proyectos con soluciones avanzadas de Soluciones Eléctricas YA y mejora la eficiencia en la gestión de instalaciones eléctricas.",
      svg: "tools",
      src: tools,
      alt: "Herramientas y equipos eléctricos en obra",
      first: true,
    },
    {
      heading: "Interfaces Intuitivas",
      content:
        "Gestiona tus proyectos con nuestras interfaces intuitivas, organizando y supervisando instalaciones eléctricas de forma ágil.",
      svg: "dashboard",
      src: dashboard,
      alt: "Plataforma de gestión intuitiva",
      second: true,
    },
    {
      heading: "Características Robustas",
      content:
        "Maximiza la productividad con características diseñadas para optimizar cada etapa del proceso eléctrico, logrando resultados excepcionales.",
      svg: "house",
      src: construction,
      alt: "Estructura metálica en construcción",
    },
  ]}
  
  />

  <TestimonialsSection
    title="Acelera tus Proyectos Eléctricos"
    subTitle="En Soluciones Eléctricas YA SAS, garantizamos un inicio rápido con soluciones inmediatas y personalizadas. Experimenta la velocidad y calidad en cada proyecto de iluminación y mobiliario."
    testimonials={[
      {
        content:
          "Soluciones Eléctricas YA SAS ha transformado la eficiencia de nuestros proyectos. La implementación fue rápida y sus tiempos de respuesta son impresionantes. ¡Un verdadero cambio en el sector eléctrico!",
        author: "Samantha Ruiz",
        role: "Directora de Operaciones | ConstructIt Inc.",
        avatarSrc:
          "https://images.unsplash.com/photo-1593104547489-5cfb3839a3b5?q=80&w=1453&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D8&auto=format&fit=facearea&facepad=2&w=320&h=320&q=80",
      },
    ]}
    statistics={[
      {
        count: "20+ años",
        description: "de experiencia en soluciones eléctricas y de iluminación",
      },
      {
        count: "35%",
        description:
          "de aumento en la eficiencia de proyectos con nuestras soluciones eléctricas",
      },
      {
        count: "15.3%",
        description:
          "reducción en costos de mantenimiento reportada por nuestros clientes de largo plazo",
      },
      {
        count: "2x",
        description:
          "mayor rapidez en la implementación de soluciones innovadoras",
      },
    ]}
  />

  <PricingSection pricing={pricing} />

  <FAQ title="Preguntas<br />Frecuentes" faqs={faqs} />

  <HeroSectionAlt
    title="Iluminamos tus Proyectos"
    subTitle="En Soluciones Eléctricas YA SAS, ofrecemos soluciones integrales en iluminación y proyectos eléctricos, combinando innovación y eficiencia para transformar tus espacios."
    url="https://github.com/solucioneselectricas/YA-template"
  />

</MainLayout>
